    "fix": "eslint \"src/**/*.ts\" --fix && prettier \"src/**/*.ts\" --write"
  },
  "dependencies": {
    "axios": "0.24.0",
    "bson": "6.10.4",
    "dateformat": "5.0.3",
    "lodash": "4.17.5",
